---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProfileCard from '../components/ProfileCard.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import DigitalClock from '../components/DigitalClock.astro';
import Footer from '../components/Footer.astro';
import { siteConfig, navigationConfig } from '../../astro.config.mjs';
---

<Layout title={siteConfig.title}>
  <div class="page-wrapper">
    <Header />
    
    <main class="main-content">
      <div class="container">
        <!-- 左栏：站长信息 -->
        <aside class="sidebar-left">
          <ProfileCard />
        </aside>
        
        <!-- 中栏：欢迎区域 -->
        <section class="content-main">
          <div class="welcome-card">
            <div class="card-glow"></div>
            <div class="welcome-content">
              <h1 class="welcome-title">
                <i class="ri-home-smile-line"></i>
                欢迎来到{siteConfig.headerTitle}
              </h1>
              <p class="welcome-desc">{siteConfig.footerDescription}</p>
              
              <div class="welcome-actions">
                {navigationConfig.home.map((link) => (
                  <a 
                    href={link.url} 
                    class="action-btn"
                    target={link.target || "_self"}
                    style={`--btn-color: ${link.color || '#10b981'}; --btn-bg: ${link.color ? link.color + '33' : 'rgba(16, 185, 129, 0.2)'}`}
                  >
                    <i class={link.icon || "ri-external-link-line"}></i>
                    {link.name}
                  </a>
                ))}
              </div>
              
              <!-- 一言 -->
              <div class="hitokoto-container">
                <div class="hitokoto-content">
                  <i class="ri-double-quotes-l hitokoto-icon"></i>
                  <p class="hitokoto-text" id="hitokotoText">正在加载一言...</p>
                  <i class="ri-double-quotes-r hitokoto-icon"></i>
                </div>
                <p class="hitokoto-from" id="hitokotoFrom"></p>
              </div>
            </div>
          </div>
        </section>
        
        <!-- 右栏：天气和时钟 -->
        <aside class="sidebar-right">
          <WeatherWidget />
          <DigitalClock />
        </aside>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>

<script>
  // 加载一言
  async function loadHitokoto() {
    const hitokotoText = document.getElementById('hitokotoText');
    const hitokotoFrom = document.getElementById('hitokotoFrom');
    
    try {
      const response = await fetch('https://v1.hitokoto.cn/?c=a&c=b&c=c&c=d&c=e&c=f&c=g&c=h&c=i&c=j&c=k&c=l');
      const data = await response.json();
      
      if (hitokotoText && hitokotoFrom) {
        hitokotoText.textContent = data.hitokoto;
        hitokotoFrom.textContent = `——${data.from}`;
      }
    } catch (error) {
      console.error('加载一言失败:', error);
      if (hitokotoText) {
        hitokotoText.textContent = '生活就像海洋，只有意志坚强的人，才能到达彼岸。';
      }
      if (hitokotoFrom) {
        hitokotoFrom.textContent = '——马克思';
      }
    }
  }
  
  // 页面加载时获取一言
  document.addEventListener('DOMContentLoaded', loadHitokoto);
</script>

<style>
  .welcome-card {
    position: relative;
    background: rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 3rem 2rem;
    overflow: hidden;
    text-align: center;
  }

  .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.15) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .welcome-card:hover .card-glow {
    opacity: 1;
  }

  .welcome-content {
    position: relative;
    z-index: 1;
  }

  .welcome-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #6ee7b7, #34d399, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .welcome-title i {
    -webkit-text-fill-color: initial;
    font-size: 1.8rem;
  }

  .welcome-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .welcome-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: var(--btn-bg, rgba(255, 255, 255, 0.1));
    border: 1px solid var(--btn-color, rgba(255, 255, 255, 0.2));
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .action-btn:hover {
    background: var(--btn-color, rgba(255, 255, 255, 0.2));
    transform: translateY(-2px);
    box-shadow: 0 8px 20px var(--btn-shadow, rgba(0, 0, 0, 0.3));
  }

  /* 一言样式 */
  .hitokoto-container {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .hitokoto-container:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(16, 185, 129, 0.3);
  }

  .hitokoto-content {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
  }

  .hitokoto-icon {
    color: rgba(16, 185, 129, 0.5);
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .hitokoto-text {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    line-height: 1.6;
    font-style: italic;
    margin: 0;
  }

  .hitokoto-from {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem;
    text-align: right;
    margin: 0;
    padding-right: 1rem;
  }

  @media (max-width: 768px) {
    .welcome-title {
      font-size: 1.5rem;
    }

    .welcome-actions {
      flex-direction: column;
    }

    .action-btn {
      width: 100%;
      justify-content: center;
    }
    
    .hitokoto-text {
      font-size: 1rem;
    }
    
    .hitokoto-container {
      padding: 1rem;
    }
  }
</style>

<style>
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main-content {
    flex: 1;
    padding: 2rem 1rem;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 300px 1fr 280px;
    gap: 2rem;
    align-items: start;
  }

  /* 左栏 */
  .sidebar-left {
    position: sticky;
    top: 100px;
  }

  /* 中栏 */
  .content-main {
    min-width: 0;
  }

  /* 右栏 */
  .sidebar-right {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* 响应式设计 */
  @media (max-width: 1200px) {
    .container {
      grid-template-columns: 260px 1fr 240px;
      gap: 1.5rem;
    }
  }

  @media (max-width: 992px) {
    .container {
      grid-template-columns: 1fr;
      max-width: 700px;
    }

    .sidebar-left,
    .sidebar-right {
      position: static;
    }
  }
</style>