---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig, websitesConfig } from '../../astro.config.mjs';
---

<Layout title={`${websitesConfig.title} - ${siteConfig.title}`}>
  <div class="page-wrapper">
    <Header />
    
    <main class="main-content">
      <div class="sites-container">
        <div class="sites-header">
          <h1 class="sites-title">
            <i class="ri-earth-line"></i>
            {websitesConfig.title}
          </h1>
          <p class="sites-description">{websitesConfig.description}</p>
        </div>
        
        <div class="sites-grid">
          {websitesConfig.items.map((site) => (
            <a href={site.url} target="_blank" rel="noopener noreferrer" class="site-card" style={`--accent-color: ${site.color}`}>
              <div class="card-glow"></div>
              <div class="card-icon">
                <i class={site.icon}></i>
              </div>
              <div class="card-content">
                <h3 class="card-title">{site.name}</h3>
                <p class="card-description">{site.description}</p>
              </div>
              <div class="card-arrow">
                <i class="ri-arrow-right-up-line"></i>
              </div>
            </a>
          ))}
        </div>
      </div>
    </main>
    
    <Footer />
  </div>
</Layout>

<style>
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .main-content {
    flex: 1;
    padding: 2rem 1rem;
  }

  .sites-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .sites-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .sites-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #6ee7b7, #34d399, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .sites-title i {
    -webkit-text-fill-color: initial;
    font-size: 2.2rem;
  }

  .sites-description {
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.1rem;
  }

  .sites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .site-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .site-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3), 0 0 20px color-mix(in srgb, var(--accent-color) 30%, transparent);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 30% 50%, var(--accent-color) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .site-card:hover .card-glow {
    opacity: 0.15;
  }

  .card-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--accent-color) 20%, transparent);
    border-radius: 12px;
    flex-shrink: 0;
  }

  .card-icon i {
    font-size: 1.8rem;
    color: var(--accent-color);
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    color: #fff;
  }

  .card-description {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
  }

  .card-arrow {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .site-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .card-arrow i {
    font-size: 1.1rem;
    color: var(--accent-color);
  }

  @media (max-width: 768px) {
    .sites-title {
      font-size: 2rem;
    }

    .sites-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
