---
import { bgConfig } from '../../astro.config.mjs';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet" />
  <script client:load>
    // 客户端路由实现
    class ClientRouter {
      constructor() {
        this.init();
      }

      init() {
        // 监听所有链接点击
        document.addEventListener('click', (e) => {
          const link = e.target.closest('a');
          if (link && this.shouldHandleLink(link)) {
            e.preventDefault();
            this.navigate(link.href);
          }
        });

        // 监听浏览器历史变化
        window.addEventListener('popstate', (e) => {
          if (e.state) {
            this.loadPage(e.state.url, false);
          }
        });
      }

      shouldHandleLink(link) {
        // 只处理站内链接，不处理外部链接和特殊链接
        return (
          link.host === window.location.host &&
          !link.getAttribute('target') &&
          !link.hasAttribute('data-no-router') &&
          link.href !== window.location.href
        );
      }

      async navigate(url) {
        // 开始视图过渡
        if (document.startViewTransition) {
          document.startViewTransition(() => {
            this.loadPage(url, true);
          });
        } else {
          // 回退方案
          this.loadPage(url, true);
        }
      }

      async loadPage(url, pushState = true) {
        try {
          // 加载新页面
          const response = await fetch(url);
          if (!response.ok) throw new Error('Network response was not ok');

          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          // 更新页面内容
          this.updatePage(doc, url);

          // 更新历史记录
          if (pushState) {
            history.pushState({ url }, '', url);
          }

          // 更新页面标题
          const newTitle = doc.querySelector('title')?.textContent;
          if (newTitle) {
            document.title = newTitle;
          }

        } catch (error) {
          console.error('Error loading page:', error);
          // 回退到正常导航
          window.location.href = url;
        }
      }

      updatePage(doc, url) {
        // 找到主要内容区域并更新
        const mainContent = document.querySelector('main');
        const newMainContent = doc.querySelector('main');

        if (mainContent && newMainContent) {
          mainContent.classList.remove('page-loaded');
          // 强制重排
          void mainContent.offsetWidth;
          mainContent.innerHTML = newMainContent.innerHTML;
          mainContent.classList.add('page-loaded');
          
          // 重新初始化页面上的脚本
          this.initScripts();
        }

        // 更新活动链接状态
        this.updateActiveLinks(url);
        
        // 重新应用RemixIcon样式（防止无刷新加载时图标闪烁）
        this.reapplyRemixIcon();
      }
      
      reapplyRemixIcon() {
        // 检查RemixIcon是否已加载
        const existingLink = document.querySelector('link[href*="remixicon"]');
        if (!existingLink) {
          // 如果未加载，重新添加链接
          const link = document.createElement('link');
          link.href = 'https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css';
          link.rel = 'stylesheet';
          document.head.appendChild(link);
        }
        
        // 强制重绘所有图标
        const icons = document.querySelectorAll('[class*="ri-"]');
        icons.forEach(icon => {
          icon.style.display = 'none';
          icon.offsetHeight; // 强制重排
          icon.style.display = '';
        });
      }

      updateActiveLinks(url) {
        // 更新导航链接的活动状态
        const links = document.querySelectorAll('.nav-link');
        links.forEach(link => {
          if (link.href === url) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }

      initScripts() {
        // 重新初始化页面上的脚本
        // 这里可以根据需要添加特定的脚本初始化逻辑
      }
    }

    // 初始化客户端路由
    document.addEventListener('DOMContentLoaded', () => {
      new ClientRouter();
    });
  </script>
  <style>
    /* 页面过渡动画 */
    main {
      position: relative;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    main:not(.page-loaded) {
      opacity: 0;
      transform: translateY(20px);
    }

    main.page-loaded {
      opacity: 1;
      transform: translateY(0);
    }

    /* 视图过渡动画 */
    @view-transition {
      navigation: auto;
    }

    @keyframes fade-in {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slide-up {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* 为不同元素定义过渡效果 */
    .page-wrapper {
      view-transition-name: page-wrapper;
    }

    @view-transition-new(page-wrapper),
    @view-transition-old(page-wrapper) {
      animation-duration: 0.3s;
    }

    @view-transition-new(page-wrapper) {
      animation-name: slide-up;
    }

    @view-transition-old(page-wrapper) {
      animation-name: fade-in;
      opacity: 0;
    }
  </style>
</head>
<body>
  <div class="bg-container" style={bgConfig.enable ? `background-image: url('${bgConfig.imageUrl}')` : undefined}>
    <div class="bg-overlay"></div>
    <canvas id="starfield" class="starfield"></canvas>
  </div>
  <slot />
  
  <script client:load>
    // 星空粒子动画
    (function() {
      const canvas = document.getElementById('starfield');
      if (!canvas) return;
      
      const ctx = canvas.getContext('2d');
      let width, height;
      let stars = [];
      let shootingStars = [];
      
      // 设置画布大小
      function resize() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      }
      
      // 星星类
      class Star {
        constructor() {
          this.reset();
        }
        
        reset() {
          this.x = Math.random() * width;
          this.y = Math.random() * height;
          this.size = Math.random() * 1.5 + 0.5;
          this.speedX = (Math.random() - 0.5) * 0.3;
          this.speedY = (Math.random() - 0.5) * 0.3;
          this.opacity = Math.random() * 0.5 + 0.3;
          this.twinkleSpeed = Math.random() * 0.02 + 0.01;
          this.twinklePhase = Math.random() * Math.PI * 2;
        }
        
        update() {
          this.x += this.speedX;
          this.y += this.speedY;
          this.twinklePhase += this.twinkleSpeed;
          
          // 边界检查
          if (this.x < 0) this.x = width;
          if (this.x > width) this.x = 0;
          if (this.y < 0) this.y = height;
          if (this.y > height) this.y = 0;
        }
        
        draw() {
          const twinkle = Math.sin(this.twinklePhase) * 0.3 + 0.7;
          const currentOpacity = this.opacity * twinkle;
          
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${currentOpacity})`;
          ctx.fill();
          
          // 添加光晕效果
          const gradient = ctx.createRadialGradient(
            this.x, this.y, 0,
            this.x, this.y, this.size * 3
          );
          gradient.addColorStop(0, `rgba(255, 255, 255, ${currentOpacity * 0.3})`);
          gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.size * 3, 0, Math.PI * 2);
          ctx.fillStyle = gradient;
          ctx.fill();
        }
      }
      
      // 流星类
      class ShootingStar {
        constructor() {
          this.reset();
        }
        
        reset() {
          this.x = Math.random() * width;
          this.y = 0;
          this.length = Math.random() * 80 + 50;
          this.speed = Math.random() * 10 + 8;
          this.angle = Math.random() * Math.PI / 4 + Math.PI / 4;
          this.opacity = 1;
          this.fadeSpeed = 0.015;
          this.active = true;
        }
        
        update() {
          if (!this.active) return;
          
          this.x += Math.cos(this.angle) * this.speed;
          this.y += Math.sin(this.angle) * this.speed;
          this.opacity -= this.fadeSpeed;
          
          if (this.opacity <= 0 || this.x > width || this.y > height) {
            this.active = false;
          }
        }
        
        draw() {
          if (!this.active) return;
          
          const tailX = this.x - Math.cos(this.angle) * this.length;
          const tailY = this.y - Math.sin(this.angle) * this.length;
          
          const gradient = ctx.createLinearGradient(this.x, this.y, tailX, tailY);
          gradient.addColorStop(0, `rgba(255, 255, 255, ${this.opacity})`);
          gradient.addColorStop(0.1, `rgba(200, 230, 255, ${this.opacity * 0.8})`);
          gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
          
          ctx.beginPath();
          ctx.moveTo(this.x, this.y);
          ctx.lineTo(tailX, tailY);
          ctx.strokeStyle = gradient;
          ctx.lineWidth = 2;
          ctx.lineCap = 'round';
          ctx.stroke();
          
          // 流星头部光点
          ctx.beginPath();
          ctx.arc(this.x, this.y, 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
          ctx.fill();
        }
      }
      
      // 初始化星星
      function initStars() {
        stars = [];
        const starCount = Math.floor((width * height) / 8000);
        for (let i = 0; i < starCount; i++) {
          stars.push(new Star());
        }
      }
      
      // 动画循环
      function animate() {
        ctx.clearRect(0, 0, width, height);
        
        // 绘制星星
        stars.forEach(star => {
          star.update();
          star.draw();
        });
        
        // 随机生成流星
        if (Math.random() < 0.005 && shootingStars.length < 2) {
          shootingStars.push(new ShootingStar());
        }
        
        // 更新和绘制流星
        shootingStars = shootingStars.filter(star => star.active);
        shootingStars.forEach(star => {
          star.update();
          star.draw();
        });
        
        requestAnimationFrame(animate);
      }
      
      // 初始化
      resize();
      initStars();
      animate();
      
      // 窗口大小改变时重新初始化
      window.addEventListener('resize', () => {
        resize();
        initStars();
      });
    })();
  </script>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    min-height: 100vh;
    color: #fff;
    overflow-x: hidden;
  }

  .bg-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    z-index: -2;
  }

  .bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(10, 40, 20, 0.93) 0%,
      rgba(20, 80, 40, 0.83) 50%,
      rgba(10, 50, 30, 0.93) 100%
    );

  }

  .starfield {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.1);
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #10b981, #34d399);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #059669, #10b981);
  }
</style>
