<script client:load>
  // 轻量级无刷新加载实现
  class ClientRouter {
    constructor() {
      this.isLoading = false;
      this.init();
    }

    init() {
      // 监听所有链接点击
      document.addEventListener('click', (e) => {
        const link = e.target.closest('a');
        if (link && this.shouldHandleLink(link)) {
          e.preventDefault();
          this.navigate(link.href);
        }
      });

      // 监听浏览器历史变化
      window.addEventListener('popstate', (e) => {
        if (e.state && e.state.url) {
          this.loadPage(e.state.url, false);
        }
      });
    }

    shouldHandleLink(link) {
      // 只处理站内链接，不处理外部链接和特殊链接
      try {
        const linkUrl = new URL(link.href);
        const currentUrl = new URL(window.location.href);
        
        // 规范化 URL 比较
        const normalizedLinkUrl = linkUrl.origin + linkUrl.pathname.replace(/\/$/, '') + linkUrl.search;
        const normalizedCurrentUrl = currentUrl.origin + currentUrl.pathname.replace(/\/$/, '') + currentUrl.search;
        
        return (
          linkUrl.origin === currentUrl.origin &&
          !link.getAttribute('target') &&
          !link.hasAttribute('data-no-router') &&
          normalizedLinkUrl !== normalizedCurrentUrl
        );
      } catch (error) {
        return false;
      }
    }

    async navigate(url) {
      if (this.isLoading) return;
      
      this.isLoading = true;
      try {
        // 显示加载指示器
        this.showLoading();
        
        // 加载页面
        await this.loadPage(url, true);
      } catch (error) {
        console.error('Navigation error:', error);
        // 回退到正常导航
        window.location.href = url;
      } finally {
        this.isLoading = false;
        this.hideLoading();
      }
    }

    async loadPage(url, pushState = true) {
      try {
        // 加载新页面
        const response = await fetch(url);
        if (!response.ok) throw new Error('Network response was not ok');

        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        // 更新页面内容
        this.updatePage(doc, url);

        // 更新历史记录
        if (pushState) {
          history.pushState({ url }, '', url);
        }

        // 更新页面标题
        const newTitle = doc.querySelector('title')?.textContent;
        if (newTitle) {
          document.title = newTitle;
        }

        // 触发页面加载完成事件
        this.triggerPageLoadEvent();

      } catch (error) {
        console.error('Error loading page:', error);
        throw error;
      }
    }

    updatePage(doc, url) {
      // 找到主要内容区域并更新
      const mainContent = document.querySelector('main');
      const newMainContent = doc.querySelector('main');

      if (mainContent && newMainContent) {
        // 开始过渡动画
        mainContent.style.opacity = '0';
        mainContent.style.transform = 'translateY(20px)';
        
        // 强制重排
        void mainContent.offsetWidth;
        
        // 更新内容
        mainContent.innerHTML = newMainContent.innerHTML;
        
        // 结束过渡动画
        mainContent.style.opacity = '1';
        mainContent.style.transform = 'translateY(0)';
        
        // 重新初始化页面上的脚本
        this.initPageScripts();
      }

      // 更新活动链接状态
      this.updateActiveLinks(url);
    }

    updateActiveLinks(url) {
      // 更新导航链接的活动状态
      const links = document.querySelectorAll('.nav-link');
      links.forEach(link => {
        try {
          const linkUrl = new URL(link.href);
          const currentUrl = new URL(url);
          
          const normalizedLinkUrl = linkUrl.origin + linkUrl.pathname.replace(/\/$/, '');
          const normalizedCurrentUrl = currentUrl.origin + currentUrl.pathname.replace(/\/$/, '');
          
          if (normalizedLinkUrl === normalizedCurrentUrl) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        } catch (error) {
          // 忽略无效链接
        }
      });
    }

    initPageScripts() {
      // 重新初始化页面上的脚本
      // 查找页面中的脚本并执行
      const scripts = document.querySelectorAll('main script');
      scripts.forEach(script => {
        if (script.type === 'module') {
          // 对于 ES 模块，创建新的脚本标签
          const newScript = document.createElement('script');
          newScript.type = 'module';
          if (script.src) {
            newScript.src = script.src;
          } else {
            newScript.textContent = script.textContent;
          }
          script.parentNode.replaceChild(newScript, script);
        } else {
          // 对于普通脚本，直接执行
          try {
            eval(script.textContent);
          } catch (error) {
            console.error('Error executing script:', error);
          }
        }
      });
    }

    showLoading() {
      // 创建并显示加载指示器
      let loader = document.getElementById('page-loader');
      if (!loader) {
        loader = document.createElement('div');
        loader.id = 'page-loader';
        loader.innerHTML = '<div class="loader-spinner"></div>';
        document.body.appendChild(loader);
      }
      loader.style.display = 'flex';
    }

    hideLoading() {
      // 隐藏加载指示器
      const loader = document.getElementById('page-loader');
      if (loader) {
        loader.style.display = 'none';
      }
    }

    triggerPageLoadEvent() {
      // 触发自定义页面加载事件
      const event = new CustomEvent('pageLoaded', {
        bubbles: true,
        cancelable: true
      });
      document.dispatchEvent(event);
    }
  }

  // 初始化客户端路由 - 确保只初始化一次
  if (typeof window !== 'undefined' && !window.ClientRouterInstance) {
    window.ClientRouterInstance = new ClientRouter();
  }
</script>

<style>
  /* 页面过渡动画 */
  main {
    position: relative;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* 加载指示器样式 */
  #page-loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.9);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(2px);
  }

  .loader-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #f3f3f3;
    border-top: 3px solid #3498db;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>
