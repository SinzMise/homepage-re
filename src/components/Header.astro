---
import { navigationConfig, siteConfig } from '../../astro.config.mjs';
---

<header class="header">
  <div class="header-content">
    <div class="logo">
      <i class="ri-home-5-line logo-icon"></i>
      <span class="logo-text">{siteConfig.headerTitle}</span>
    </div>
    <button class="menu-toggle" id="menuToggle">
      <i class="ri-menu-line menu-icon"></i>
      <i class="ri-close-line close-icon"></i>
    </button>
    <nav class="nav" id="navMenu">
      {navigationConfig.header.map((link) => (
        <a 
          href={link.url} 
          class={`nav-link ${link.active ? 'active' : ''}`}
          target={link.target || "_self"}
        >
          {link.name}
        </a>
      ))}
    </nav>
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const menuToggle = document.getElementById('menuToggle');
      const navMenu = document.getElementById('navMenu');
      
      if (menuToggle && navMenu) {
        menuToggle.addEventListener('click', () => {
          navMenu.classList.toggle('open');
          menuToggle.classList.toggle('active');
        });
        
        // 点击链接后关闭菜单
        const navLinks = navMenu.querySelectorAll('.nav-link');
        navLinks.forEach(link => {
          link.addEventListener('click', () => {
            if (window.innerWidth < 768) {
              navMenu.classList.remove('open');
              menuToggle.classList.remove('active');
            }
          });
        });
      }
    });
  </script>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(0,0,0,0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #6ee7b7, #34d399, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .logo-icon {
    font-size: 1.8rem;
    -webkit-text-fill-color: initial;
    animation: twinkle 2s ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }

  .menu-toggle {
    display: none;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 101;
  }

  .menu-icon,
  .close-icon {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .menu-icon {
    display: block;
  }

  .close-icon {
    display: none;
  }

  .menu-toggle.active .menu-icon {
    display: none;
  }

  .menu-toggle.active .close-icon {
    display: block;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.3), rgba(52, 211, 153, 0.3));
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 20px;
    z-index: -1;
  }

  .nav-link:hover::before,
  .nav-link.active::before {
    opacity: 1;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #fff;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .header-content {
      padding: 1rem;
    }
    
    .logo {
      font-size: 1.2rem;
    }
    
    .logo-icon {
      font-size: 1.5rem;
    }
    
    .menu-toggle {
      display: block;
    }
    
    .nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      height: 100vh;
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(10px);
      border-left: 1px solid rgba(255, 255, 255, 0.1);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      transition: right 0.3s ease;
      z-index: 100;
    }
    
    .nav.open {
      right: 0;
    }
    
    .nav-link {
      font-size: 1.2rem;
      padding: 1rem 2rem;
    }
  }
</style>
